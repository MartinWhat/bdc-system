generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// 状态枚举
enum ReceiveStatus {
  PENDING
  ISSUED
  COMPLETED
  OBJECTION
  CANCELLED
}

enum ObjectionStatus {
  PENDING
  RESOLVED
  REJECTED
}

enum BdcStatus {
  PENDING
  APPROVED
  ISSUED
  CANCELLED
}

// 村集体证书状态
enum CollectiveCertStatus {
  IN_STOCK // 在库
  OUT_STOCK // 已出库
  RETURNED // 已归还
  CANCELLED // 已注销
  FROZEN // 已冻结
  PENDING_APPROVE // 待审核入库
}

// 证书操作类型
enum CertOperationType {
  STOCK_APPLY // 入库申请
  STOCK_APPROVE // 入库审核通过
  STOCK_REJECT // 入库审核驳回
  OUT_APPLY // 出库申请
  OUT_APPROVE // 出库审核通过
  OUT_REJECT // 出库审核驳回
  RETURN // 归还
  FREEZE // 冻结
  UNFREEZE // 解冻
  CANCEL // 注销
}

model SysKeyVersion {
  id        String   @id @default(cuid())
  keyType   String
  version   Int
  keyData   String
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  expiresAt DateTime

  // 密钥元数据（密钥轮换增强）
  createdBy          String
  encryptedDataCount Int?      @default(0) // 使用该密钥加密的数据数量
  migratedToKeyId    String? // 迁移目标密钥 ID（如果已迁移）
  isArchived         Boolean   @default(false) // 是否已归档
  archivedAt         DateTime?
  deletedAt          DateTime?

  @@index([keyType, isActive, isArchived])
  @@index([keyType, expiresAt])
  @@map("sys_key_version")
}

model SysUser {
  id               String             @id @default(cuid())
  username         String             @unique
  passwordHash     String
  salt             String
  realName         String
  idCard           String?
  idCardHash       String?
  phone            String?
  phoneHash        String?
  email            String?
  avatar           String?
  status           String             @default("ACTIVE")
  twoFactorEnabled Boolean            @default(false)
  lastLoginAt      DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  createdBy        String?
  villageId        String? // 所属村居 ID
  village          SysVillage?        @relation(fields: [villageId], references: [id])
  createdRecords   OperationLog[]     @relation("UserCreatedRecords")
  sessions         SysSession[]
  roles            UserRole[]
  notifications    Notification[]
  readRecords      NotificationRead[]

  @@index([villageId])
  @@map("sys_user")
}

model SysRole {
  id          String           @id @default(cuid())
  name        String           @unique
  code        String           @unique
  description String?
  status      String           @default("ACTIVE")
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  permissions RolePermission[]
  users       UserRole[]

  @@map("sys_role")
}

model SysPermission {
  id          String           @id @default(cuid())
  name        String
  code        String           @unique
  type        String
  resource    String?
  description String?
  createdAt   DateTime         @default(now())
  roles       RolePermission[]

  @@map("sys_permission")
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())
  role      SysRole  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user      SysUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("sys_user_role")
}

model RolePermission {
  id           String        @id @default(cuid())
  roleId       String
  permissionId String
  createdAt    DateTime      @default(now())
  permission   SysPermission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         SysRole       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("sys_role_permission")
}

model SysSession {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Refresh Token 字段（双 Token 机制）
  // 注意：refreshToken 存储哈希值，而非明文
  refreshTokenHash      String?   @unique
  refreshTokenExpiresAt DateTime?
  lastActivityAt        DateTime?
  deviceFingerprint     String?

  user SysUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshTokenHash])
  @@map("sys_session")
}

model SysTown {
  id        String       @id @default(cuid())
  code      String       @unique
  name      String
  status    String       @default("ACTIVE")
  sortOrder Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  villages  SysVillage[]

  @@map("sys_town")
}

model SysVillage {
  id              String           @id @default(cuid())
  townId          String
  code            String           @unique
  name            String
  status          String           @default("ACTIVE")
  sortOrder       Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  town            SysTown          @relation(fields: [townId], references: [id])
  users           SysUser[]
  bdcs            ZjdBdc[]
  collectiveCerts CollectiveCert[]

  @@index([townId])
  @@map("sys_village")
}

model ZjdBdc {
  id             String             @id @default(cuid())
  villageId      String
  certNo         String             @unique
  ownerName      String
  idCard         String
  idCardHash     String
  phone          String?
  phoneHash      String?
  address        String
  area           Float
  landUseType    String
  status         String             @default("PENDING")
  approvedArea   Float?
  approvedDate   DateTime?
  certIssuedDate DateTime?
  remark         String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  createdBy      String
  operationLogs  OperationLog[]
  village        SysVillage         @relation(fields: [villageId], references: [id])
  receiveRecords ZjdReceiveRecord[]

  @@index([villageId])
  @@index([status])
  @@map("zjd_bdc")
}

model ZjdReceiveRecord {
  id                 String        @id @default(cuid())
  bdcId              String
  receiverName       String?
  receiverIdCard     String?
  receiverIdCardHash String?
  receiverPhone      String?
  receiverPhoneHash  String?
  idCardFrontPhoto   String?
  idCardBackPhoto    String?
  scenePhoto         String?
  status             String        @default("PENDING")
  applyDate          DateTime      @default(now())
  issueDate          DateTime?
  receiveDate        DateTime?
  signedBy           String?
  signedDate         DateTime?
  remark             String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  createdBy          String
  objections         Objection[]
  processNodes       ProcessNode[]
  bdc                ZjdBdc        @relation(fields: [bdcId], references: [id], onDelete: Cascade)

  @@index([bdcId])
  @@index([status])
  @@map("zjd_receive_record")
}

model ProcessNode {
  id              String           @id @default(cuid())
  receiveRecordId String
  nodeType        String
  nodeName        String
  operatorId      String?
  operatorName    String?
  description     String?
  metadata        String?
  createdAt       DateTime         @default(now())
  receiveRecord   ZjdReceiveRecord @relation(fields: [receiveRecordId], references: [id], onDelete: Cascade)

  @@index([receiveRecordId])
  @@map("zjd_process_node")
}

model Objection {
  id              String           @id @default(cuid())
  receiveRecordId String
  objectionType   String
  description     String
  status          String           @default("PENDING")
  resolveRemark   String?
  resolverId      String?
  resolverName    String?
  resolvedAt      DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  receiveRecord   ZjdReceiveRecord @relation(fields: [receiveRecordId], references: [id], onDelete: Cascade)

  @@index([receiveRecordId])
  @@index([status])
  @@map("zjd_objection")
}

model OperationLog {
  id           String   @id @default(cuid())
  userId       String
  bdcId        String?
  action       String
  module       String
  description  String
  ipAddress    String?
  userAgent    String?
  requestData  String?
  responseData String?
  status       String   @default("SUCCESS")
  createdAt    DateTime @default(now())
  bdc          ZjdBdc?  @relation(fields: [bdcId], references: [id])
  user         SysUser  @relation("UserCreatedRecords", fields: [userId], references: [id])

  @@index([userId])
  @@index([bdcId])
  @@map("sys_operation_log")
}

// 村集体所有权证书表
model CollectiveCert {
  id                 String               @id @default(cuid())
  certNo             String               @unique
  ownerName          String
  ownerType          String               @default("VILLAGE_COLLECTIVE") // VILLAGE_COLLECTIVE, TOWN_COLLECTIVE
  villageId          String
  idCard             String?
  idCardHash         String?
  phone              String?
  phoneHash          String?
  address            String
  area               Float
  landUseType        String?
  certIssueDate      DateTime?
  certExpiryDate     DateTime?
  status             CollectiveCertStatus @default(PENDING_APPROVE)
  isFrozen           Boolean              @default(false)
  freezeReason       String?
  freezeBy           String?
  freezeAt           DateTime?
  // 入库信息
  stockBy            String?
  stockAt            DateTime?
  stockRemark        String?
  approveBy          String?
  approveAt          DateTime?
  approveRemark      String?
  // 出库信息
  outBy              String?
  outAt              DateTime?
  outReason          String?
  outApproveBy       String?
  outApproveAt       DateTime?
  outApproveRemark   String?
  expectedReturnDate DateTime?
  actualReturnDate   DateTime?
  // 归还信息
  returnBy           String?
  returnAt           DateTime?
  returnRemark       String?
  // 注销信息
  cancelBy           String?
  cancelAt           DateTime?
  cancelReason       String?
  // 附件
  attachments        String? // JSON 格式存储附件列表
  remark             String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  createdBy          String
  village            SysVillage           @relation(fields: [villageId], references: [id])
  operations         CertOperation[]

  @@index([villageId])
  @@index([status])
  @@index([ownerType])
  @@index([certNo])
  @@map("collective_cert")
}

// 证书操作记录表
model CertOperation {
  id            String            @id @default(cuid())
  certId        String
  operationType CertOperationType
  operatorId    String?
  operatorName  String?
  description   String?
  metadata      String? // JSON 格式存储额外信息
  createdAt     DateTime          @default(now())
  cert          CollectiveCert    @relation(fields: [certId], references: [id], onDelete: Cascade)

  @@index([certId])
  @@index([operationType])
  @@map("cert_operation")
}

// 通知类型
enum NotificationType {
  SYSTEM
  POLICY
  ANNOUNCEMENT
}

// 通知优先级
enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// 通知状态
enum NotificationStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// 通知公告
model Notification {
  id           String               @id @default(cuid())
  title        String
  content      String // 富文本 HTML 内容
  type         NotificationType     @default(SYSTEM)
  priority     NotificationPriority @default(NORMAL)
  status       NotificationStatus   @default(DRAFT)
  isPopup      Boolean              @default(false)
  popupStartAt DateTime?
  popupEndAt   DateTime?
  validFrom    DateTime?
  validUntil   DateTime?
  isPinned     Boolean              @default(false)
  pdfUrl       String? // PDF 附件 URL
  authorId     String
  author       SysUser              @relation(fields: [authorId], references: [id])
  readCount    Int                  @default(0)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  publishedAt  DateTime?
  readRecords  NotificationRead[]

  @@index([type, status])
  @@index([isPopup, popupStartAt, popupEndAt])
  @@map("notification")
}

// 通知阅读记录
model NotificationRead {
  id             String       @id @default(cuid())
  notificationId String
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  userId         String
  user           SysUser      @relation(fields: [userId], references: [id])
  readAt         DateTime     @default(now())

  @@unique([notificationId, userId])
  @@index([userId])
  @@map("notification_read")
}

// 附件库
model Attachment {
  id         String   @id @default(cuid())
  name       String   // 原始文件名
  url        String   // 文件访问 URL
  fileType   String   // 文件类型：pdf, doc, docx, xls, xlsx 等
  fileSize   Int?     // 文件大小（字节）
  uploadedBy String   // 上传人 ID
  createdAt  DateTime @default(now())

  @@index([fileType])
  @@index([uploadedBy])
  @@map("attachment")
}
